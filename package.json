{
  "name": "fullyhacks2026",
  "private": true,
  "scripts": {
    "dev": "python3 -m http.server 4321 --bind 127.0.0.1",
    "backend": "python3 -m uvicorn app.main:app --reload --port 8000",
    "extract": "npm run backend",
    "build": "node scripts/gsd-static-build.mjs",
    "gsd": "gsd-sdk",
    "gsd:version": "gsd-sdk --version",
    "test:api": "python3 -m pytest tests/test_api_routes.py -q",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:api && npm run test:e2e"
  },
  "devDependencies": {
    "@gsd-build/sdk": "^0.1.0",
    "@playwright/test": "^1.49.0",
    "serve": "^14.2.4"
  }
}
