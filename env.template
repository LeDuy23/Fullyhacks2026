# Copy this file to `.env` in the project root (do not commit `.env`).
# Get a Gemini key: https://aistudio.google.com/apikey

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Maps JavaScript API + Places API (Nearby Search) must be enabled for the key.
# Reel-to-map worker also uses Places API (New) `places:searchText` server-side.
GOOGLE_MAPS_API_KEY=

# Optional: install yt-dlp in the same environment as the FastAPI app (`pip install -r requirements.txt`)
# so POST /api/jobs can download TikTok/Instagram video before Gemini video analysis.

# Instagram scraping (optional — import-from-Instagram / reels)
RAPIDAPI_KEY=
RAPIDAPI_HOST=real-time-instagram-scraper-api1.p.rapidapi.com
# Optional: override POST path if your RapidAPI provider differs (e.g. v2/media_info)
# RAPIDAPI_IG_PATH=

# Comma-separated origins for DeepDive.html (npm run dev). Override in production.
# CORS_ORIGINS=http://127.0.0.1:4321,http://localhost:4321

# --- Supabase + Next.js (`web/` app) ---
# Copy web/.env.example → web/.env.local and set:
#   NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon key from Dashboard → Settings → API>
# Apply DB migrations: from repo root, use Supabase CLI or scripts/push-supabase-migrations.sh
# Optional CLI: export SUPABASE_PROJECT_REF=your_ref when linking/pushing migrations

# TikTok + Gemini (backend): POST /tiktok/gemini-read
# Optional: save oEmbed + Gemini output to Supabase (posts + extractions). Use the service role key server-side only.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<Dashboard → Settings → API → service_role>
# Or reuse NEXT_PUBLIC_SUPABASE_URL with SUPABASE_SERVICE_ROLE_KEY.
# Request body: { "url": "...", "persist": true, "user_id": "<uuid of existing public.users row>" }
# MCP server: python mcp_servers/tiktok_gemini_mcp.py
